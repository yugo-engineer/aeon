# Copy to .env for local development
# In GitHub Actions, set these as repository secrets

# Required — Claude Code OAuth token (from `claude setup-token`)
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# X.AI (optional — for searching X/Twitter in digest/fetch-tweets skills)
XAI_API_KEY=
